@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix this: <http://purl.org/np/RAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx> .   # ← Replaced by real hash on publish
@prefix sub: <http://purl.org/np/RAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix np: <http://www.nanopub.org/nschema#> .
@prefix orcid: <https://orcid.org/> .
@prefix nt: <https://w3id.org/np/o/ntemplate/> .
@prefix npx: <http://purl.org/nanopub/x/> .
@prefix ex: <http://example.org/ontology/colorectal-triage#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

# =============================================
# HEAD
# =============================================
sub:Head {
  this: a np:Nanopublication ;
    np:hasAssertion sub:assertion ;
    np:hasProvenance sub:provenance ;
    np:hasPublicationInfo sub:pubinfo .
}

# =============================================
# ASSERTION (Core Claims)
# =============================================
sub:assertion {
  ex:ColorectalTriageChecklist a ex:TriageFramework ;
    dcterms:title "Prioritized Framework for Colorectal Cancer Patient Triage and Scheduling" ;
    ex:prioritizedFor "physician assignment and initial scheduling" .

  # Key Decision Points
  ex:RectalVsColon a ex:TriageDecisionPoint ;
    ex:decision "Rectal vs. Colon" ;
    ex:description "Rectal cancers typically require multidisciplinary evaluation (medical oncology, radiation oncology, surgical oncology) upfront, while colon cancers may go directly to surgical oncology if non-metastatic" ;
    ex:importance "Must Have" .

  ex:MetastaticVsNonMetastatic a ex:TriageDecisionPoint ;
    ex:decision "Metastatic vs. Non-metastatic" ;
    ex:description "Metastatic disease requires medical oncology evaluation with molecular testing complete; non-metastatic may prioritize surgical evaluation" ;
    ex:importance "Must Have" .

  ex:MMR_MSI_Status a ex:TriageDecisionPoint ;
    ex:decision "MMR/MSI status" ;
    ex:description "dMMR/MSI-H patients may be candidates for immunotherapy and follow different treatment algorithms" ;
    ex:importance "Must Have" .

  ex:ObstructingEmergency a ex:TriageDecisionPoint ;
    ex:decision "Obstructing/Emergency presentation" ;
    ex:description "Requires urgent surgical consultation regardless of other factors" ;
    ex:importance "Must Have" .
}

# =============================================
# PROVENANCE (Rich PROV-O)
# =============================================
sub:provenance {
  # 1. Basic derivation
  sub:assertion prov:wasDerivedFrom <https://www.nccn.org/professionals/physician_gls/pdf/colon.pdf> ;
               prov:wasDerivedFrom <https://www.nccn.org/professionals/physician_gls/pdf/rectal.pdf> ;
               prov:wasDerivedFrom <https://doi.org/10.1097/DCR.0000000000002323> .

  # 2. The nanopublication itself was generated by an activity
  this: prov:wasGeneratedBy :TriageNanopubCreation .

  # 3. Detailed Activity
  :TriageNanopubCreation a prov:Activity ;
    prov:startedAtTime "2026-06-04T21:56:00"^^xsd:dateTime ;
    prov:endedAtTime "2026-06-04T21:57:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://orcid.org/0000-0000-0000-0000> ;   # ← Your ORCID
    prov:used <https://www.nccn.org/professionals/physician_gls/pdf/colon.pdf> ,
              <https://www.nccn.org/professionals/physician_gls/pdf/rectal.pdf> ,
              <https://doi.org/10.1097/DCR.0000000000002323> .

  # 4. Qualified Derivation (more expressive)
  sub:assertion prov:qualifiedDerivation [
    a prov:Derivation ;
    prov:entity <https://www.nccn.org/professionals/physician_gls/pdf/colon.pdf> ;
    prov:hadActivity :TriageNanopubCreation
  ] ;

  prov:qualifiedDerivation [
    a prov:Derivation ;
    prov:entity <https://www.nccn.org/professionals/physician_gls/pdf/rectal.pdf> ;
    prov:hadActivity :TriageNanopubCreation
  ] ;

  prov:qualifiedDerivation [
    a prov:Derivation ;
    prov:entity <https://doi.org/10.1097/DCR.0000000000002323> ;
    prov:hadActivity :TriageNanopubCreation
  ] .

  # 5. Attribution
  sub:assertion prov:wasAttributedTo <https://orcid.org/0000-0000-0000-0000> .
  
  :TriageNanopubCreation prov:qualifiedAssociation [
    a prov:Association ;
    prov:agent <https://orcid.org/0000-0000-0000-0000> ;
    prov:hadRole ex:KnowledgeEngineer
  ] .

  # 6. Source Entities (with types and metadata)
  <https://www.nccn.org/professionals/physician_gls/pdf/colon.pdf> 
    a prov:Entity ;
    dcterms:title "NCCN Clinical Practice Guidelines in Oncology: Colon Cancer (Version 2.2026)" ;
    prov:wasAttributedTo <https://www.nccn.org/> .

  <https://www.nccn.org/professionals/physician_gls/pdf/rectal.pdf> 
    a prov:Entity ;
    dcterms:title "NCCN Clinical Practice Guidelines in Oncology: Rectal Cancer (Version 2.2026)" ;
    prov:wasAttributedTo <https://www.nccn.org/> .

  <https://doi.org/10.1097/DCR.0000000000002323> 
    a prov:Entity ;
    dcterms:title "The American Society of Colon and Rectal Surgeons Clinical Practice Guidelines for the Management of Colon Cancer" ;
    dcterms:issued "2022-02-01"^^xsd:date ;
    prov:wasAttributedTo "Vogel JD, et al." .
}

# =============================================
# PUBLICATION INFO
# =============================================
sub:pubinfo {
  this: dcterms:created "2026-06-04T21:56:00"^^xsd:dateTime ;
    dcterms:creator <https://orcid.org/0000-0000-0000-0000> ;   # ← Replace with your ORCID
    nt:wasCreatedFromTemplate <http://purl.org/np/RAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx> .
}
