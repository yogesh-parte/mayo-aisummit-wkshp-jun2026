@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix this: <http://purl.org/np/RAColorectalTriageSinglexxxxxxxxxxxxxxxx> .
@prefix sub: <http://purl.org/np/RAColorectalTriageSinglexxxxxxxxxxxxxxxx#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix np: <http://www.nanopub.org/nschema#> .
@prefix ex: <http://example.org/ontology/colorectal-triage#> .

sub:Head {
  this: a np:Nanopublication ;
    np:hasAssertion sub:assertion ;
    np:hasProvenance sub:provenance ;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  ex:ColorectalTriageChecklist a ex:TriageFramework ;
    dcterms:title "Prioritized Framework for Colorectal Cancer Patient Triage and Scheduling" ;
    ex:prioritizedFor "physician assignment and initial scheduling" .

  ex:RectalVsColon a ex:TriageDecisionPoint ;
    ex:decision "Rectal vs. Colon" ;
    ex:description "Rectal cancers typically require multidisciplinary evaluation (medical oncology, radiation oncology, surgical oncology) upfront, while colon cancers may go directly to surgical oncology if non-metastatic" ;
    ex:importance "Must Have" ;
    ex:partOf ex:ColorectalTriageChecklist .

  ex:MetastaticVsNonMetastatic a ex:TriageDecisionPoint ;
    ex:decision "Metastatic vs. Non-metastatic" ;
    ex:description "Metastatic disease requires medical oncology evaluation with molecular testing complete; non-metastatic may prioritize surgical evaluation" ;
    ex:importance "Must Have" ;
    ex:partOf ex:ColorectalTriageChecklist .

  ex:MMR_MSI_Status a ex:TriageDecisionPoint ;
    ex:decision "MMR/MSI status" ;
    ex:description "dMMR/MSI-H patients may be candidates for immunotherapy and follow different treatment algorithms" ;
    ex:importance "Must Have" ;
    ex:partOf ex:ColorectalTriageChecklist .

  ex:ObstructingEmergency a ex:TriageDecisionPoint ;
    ex:decision "Obstructing/Emergency presentation" ;
    ex:description "Requires urgent surgical consultation regardless of other factors" ;
    ex:importance "Must Have" ;
    ex:partOf ex:ColorectalTriageChecklist .
}

sub:provenance {
  sub:assertion prov:wasDerivedFrom <https://www.nccn.org/professionals/physician_gls/pdf/colon.pdf>,
                                    <https://www.nccn.org/professionals/physician_gls/pdf/rectal.pdf>,
                                    <https://doi.org/10.1097/DCR.0000000000002323> .

  this: prov:wasGeneratedBy :TriageCreationActivity .

  :TriageCreationActivity a prov:Activity ;
    prov:startedAtTime "2026-06-05T00:00:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://orcid.org/0000-0000-0000-0000> .
}

sub:pubinfo {
  this: dcterms:created "2026-06-05T00:00:00"^^xsd:dateTime ;
    dcterms:creator <https://orcid.org/0000-0000-0000-0000> .
}
